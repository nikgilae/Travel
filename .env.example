# ── Database ────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/travel_db
TEST_DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/travel_test_db

# ── Security ───────────────────────────────────────────────────────────────────
# Generate with: uv run python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-min-32-chars-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── AI Configuration ───────────────────────────────────────────────────────────
# OpenAI-compatible endpoint (e.g., OpenAI, DeepSeek, Groq, Together AI)
AI_API_KEY=your-ai-api-key
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini

# ── Google Maps API ────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ── App Configuration ──────────────────────────────────────────────────────────
# Set to true for development (verbose SQL logging, debug info)
DEBUG=false

# Frontend URL for CORS (comma-separated or JSON array)
# Examples:
#   CSV: CORS_ORIGINS=http://localhost:3000,https://myapp.com
#   JSON: CORS_ORIGINS=["http://localhost:3000","https://myapp.com"]
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000